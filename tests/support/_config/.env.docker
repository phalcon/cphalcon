# Project prefix used for Docker container names.
# Change this per folder to avoid conflicts when running multiple projects simultaneously.
# e.g. cphalcon (v5), cphalcon7 (v7)
PROJECT_PREFIX=cphalcon

# Memcached
DATA_MEMCACHED_HOST="memcached"
DATA_MEMCACHED_PORT=11211
DATA_MEMCACHED_WEIGHT=1

# MySQL
DATA_MYSQL_HOST="mysql"
DATA_MYSQL_PORT=3306
DATA_MYSQL_USER="root"
DATA_MYSQL_PASS="secret"
DATA_MYSQL_NAME="phalcon"
DATA_MYSQL_CHARSET="utf8"

# Mariadb
DATA_MARIADB_HOST="mysql"
DATA_MARIADB_PORT=3306
DATA_MARIADB_USER="root"
DATA_MARIADB_PASS="secret"
DATA_MARIADB_NAME="phalcon"
DATA_MARIADB_CHARSET="utf8"

# Postgresql
DATA_POSTGRES_HOST="postgres"
DATA_POSTGRES_PORT=5432
DATA_POSTGRES_USER="phalcon"
DATA_POSTGRES_PASS="secret"
DATA_POSTGRES_NAME="phalcon"
DATA_POSTGRES_SCHEMA="public"

# Mongo
DATA_MONGODB_HOST="127.0.0.1"
DATA_MONGODB_PORT=27017
DATA_MONGODB_USER="admin"
DATA_MONGODB_PASS=""
DATA_MONGODB_NAME="phalcon_test"

# Redis
DATA_REDIS_HOST="redis"
DATA_REDIS_PORT=6379
DATA_REDIS_NAME="0"

# Redis Cluster
DATA_REDIS_CLUSTER_HOSTS="redis-node-0:6379,redis-node-1:6379,redis-node-2:6379,redis-node-3:6379,redis-node-4:6379,redis-node-5:6379"
DATA_REDIS_CLUSTER_AUTH="bitnami"

# SQLite
DATA_SQLITE_NAME="tests/support/assets/phalcon_test.sqlite"
DATA_SQLITE_I18N_NAME="tests/support/assets/translations.sqlite"